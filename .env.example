# Environment settings
ENVIRONMENT=local
PROJECT_NAME="itaxeasy-apk-backend"

# PostgreSQL connection strings
# dev/start.sh runs postgres on port 5432 or 5433 by default
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itaxeasy

# JWT Security (our own session tokens, issued after Firebase verifies the phone)
JWT_SECRET=supersecretjwtkeyforitaxeasyapkbackend
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days in minutes

REFRESH_TOKEN_EXPIRE_MINUTES=86400  # 60 days in minutes

# Firebase Admin SDK (phone OTP auth)

# Download the service-account JSON from:
#   Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# Place it in the project root (it is gitignored) and point this at it.
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
# Optional: only needed if you want to pin the project id explicitly
FIREBASE_PROJECT_ID=
